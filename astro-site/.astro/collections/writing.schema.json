{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "image": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "status": {
      "default": "published",
      "type": "string",
      "enum": [
        "draft",
        "published"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "date"
  ]
}